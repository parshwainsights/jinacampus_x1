# Supabase/Vercel values belong in Vercel Project Settings -> Environment
# Variables. Never commit real database URLs, passwords, or application secrets.
# DATABASE_URL: Supavisor transaction-pooled runtime URL for Vercel.
# DIRECT_URL: direct Supabase database URL for Prisma migration commands.
DATABASE_URL=""
DIRECT_URL="postgresql://postgres:Namaan%40JinaCampus03@db.jcqpmdslmydxjsfdwenc.supabase.co:5432/postgres"
APP_URL=""
SESSION_COOKIE_NAME="jc_session"
SESSION_TTL_DAYS="7"
SESSION_SECRET=""
PASSWORD_PEPPER=""

# Commercial onboarding is disabled by default. Configure these values outside
# source control, run the seed once, then disable bootstrap again.
COMMERCIAL_BOOTSTRAP_ENABLED="false"
RESET_SEED_ADMIN_PASSWORD="false"
SEED_TENANT_NAME=""
SEED_TENANT_SLUG=""
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PHONE=""
SEED_ADMIN_TEMP_PASSWORD=""
SEED_INSTITUTION_NAME=""
SEED_INSTITUTION_CODE=""
SEED_BRANCH_NAME=""
SEED_BRANCH_CODE=""
SEED_ACADEMIC_YEAR_NAME=""
SEED_ACADEMIC_YEAR_START_DATE=""
SEED_ACADEMIC_YEAR_END_DATE=""

# Optional local development fixtures. This flag is rejected in production.
DEV_DEMO_SEED_ENABLED="false"
DEV_DEMO_USER_PASSWORD=""
DEV_DEMO_STAFF_PASSWORD=""

# OTP delivery adapter. Do not commit provider credentials.
OTP_QA_ENABLED="false"
SMS_PROVIDER="dev"
SMS_API_KEY=""
SMS_SENDER_ID=""
SMS_OTP_TEMPLATE_ID=""

# WhatsApp notification foundation. Keep DRY_RUN for local/dev unless a provider
# integration is approved and configured with real secrets outside git.
WHATSAPP_PROVIDER_MODE="DRY_RUN"
WHATSAPP_WEBHOOK_VERIFY_TOKEN_SHA256=""
WHATSAPP_APP_SECRET=""
