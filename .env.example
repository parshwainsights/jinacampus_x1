POSTGRES_HOST_PORT="5432"
DATABASE_URL="postgresql://jinacampus:jinacampus@localhost:5432/jinacampus?schema=public"
APP_URL="http://localhost:3000"
SESSION_COOKIE_NAME="jc_session"
SESSION_TTL_DAYS="7"
PASSWORD_PEPPER="replace-with-a-long-random-secret"
NODE_ENV="development"

# WhatsApp notification foundation. Keep DRY_RUN for local/dev unless a provider
# integration is approved and configured with real secrets outside git.
WHATSAPP_PROVIDER_MODE="DRY_RUN"
WHATSAPP_WEBHOOK_VERIFY_TOKEN_SHA256=""
WHATSAPP_APP_SECRET=""
