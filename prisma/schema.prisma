  checkOutQrToken StaffAttendanceQrToken? @relation("StaffAttendanceCheckOutQrToken", fields: [checkOutQrTokenId], references: [id], onDelete: SetNull)
  markedBy        User?                   @relation("StaffAttendanceMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)
  updatedBy       User?                   @relation("StaffAttendanceUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, branchId, staffId, attendanceDate])
