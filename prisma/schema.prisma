  updatedAt           DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([tenantId, studentId, guardianId, relation])
  @@index([tenantId, studentId, isPrimary])
  @@index([tenantId, guardianId])
  @@map("student_guardian_links")
}

model Enrollment {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  branchId       String           @db.Uuid
  academicYearId String           @db.Uuid
  studentId      String           @db.Uuid
  classSectionId String           @db.Uuid
  rollNumber     String?
  status         EnrollmentStatus @default(ACTIVE)
  enrolledOn     DateTime         @db.Date
  leftOn         DateTime?        @db.Date
  createdById    String?          @db.Uuid
  updatedById    String?          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                   Branch                    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  academicYear             AcademicYear              @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  student                  Student                   @relation(fields: [studentId], references: [id], onDelete: Restrict)
  classSection             ClassSection              @relation(fields: [classSectionId], references: [id], onDelete: Restrict)
  studentAttendanceRecords StudentAttendanceRecord[]

  @@unique([tenantId, academicYearId, studentId])
  @@unique([tenantId, academicYearId, classSectionId, rollNumber])
  @@index([tenantId, branchId, academicYearId, status])
  @@index([tenantId, classSectionId, status])
  @@map("enrollments")
}

model StudentAttendanceRecord {
  id               String                  @id @default(uuid()) @db.Uuid
  tenantId         String                  @db.Uuid
  branchId         String                  @db.Uuid
  academicYearId   String                  @db.Uuid
  classSectionId   String                  @db.Uuid
  enrollmentId     String                  @db.Uuid
  studentId        String                  @db.Uuid
  attendanceDate   DateTime                @db.Date
  sessionType      AttendanceSessionType   @default(FULL_DAY)
  status           StudentAttendanceStatus @default(NOT_MARKED)
  remarks          String?
  correctionReason String?
  markedById       String?                 @db.Uuid
  correctedById    String?                 @db.Uuid
  markedAt         DateTime?
  correctedAt      DateTime?
  lockedAt         DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Restrict)
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Restrict)
  markedBy     User?        @relation("StudentAttendanceMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)
  correctedBy  User?        @relation("StudentAttendanceCorrectedBy", fields: [correctedById], references: [id], onDelete: SetNull)

  @@unique([tenantId, academicYearId, studentId, attendanceDate, sessionType])
  @@index([tenantId, branchId, attendanceDate])
  @@index([tenantId, academicYearId, classSectionId, attendanceDate])
  @@index([tenantId, enrollmentId, attendanceDate])
  @@index([tenantId, status, attendanceDate])
  @@map("student_attendance_records")
}

model StaffProfile {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @db.Uuid
  branchId         String           @db.Uuid
  userId           String?          @unique @db.Uuid
  employeeCode     String
  firstName        String
  middleName       String?
  lastName         String?
  staffType        StaffType
  designation      String?
  department       String?
  phone            String?
  email            String?
  joiningDate      DateTime?        @db.Date
  employmentStatus EmploymentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                 Branch                  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  user                   User?                   @relation("StaffProfileUser", fields: [userId], references: [id], onDelete: SetNull)
  staffAttendanceRecords StaffAttendanceRecord[]

  @@unique([tenantId, employeeCode])
  @@index([tenantId, branchId])
  @@index([tenantId, staffType])
  @@index([tenantId, employmentStatus])
  @@map("staff_profiles")
}

model StaffAttendanceRecord {
  id                String                 @id @default(uuid()) @db.Uuid
  tenantId          String                 @db.Uuid
  branchId          String                 @db.Uuid
  academicYearId    String?                @db.Uuid
  staffId           String                 @db.Uuid
  attendanceDate    DateTime               @db.Date
  status            StaffAttendanceStatus  @default(NOT_MARKED)
  checkInAt         DateTime?
  checkOutAt        DateTime?
  workingMinutes    Int?
  checkInSource     StaffAttendanceSource?
  checkOutSource    StaffAttendanceSource?
  checkInQrTokenId  String?                @db.Uuid
  checkOutQrTokenId String?                @db.Uuid
  markedById        String?                @db.Uuid
  updatedById       String?                @db.Uuid
